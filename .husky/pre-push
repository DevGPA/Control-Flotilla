#!/usr/bin/env sh
# Pre-push — corre verificación completa local mientras GitHub Actions
# está pausado por billing. Replica el pipeline de .github/workflows/ci.yml.
#
# Para saltar en emergencia (NO recomendado):
#   git push --no-verify
#
# Remover cuando billing se resuelva y workflow_dispatch vuelva a push auto.

# Ensure node+npm en PATH (git hooks Windows MSYS pierden PATH user).
export PATH="/c/Program Files/nodejs:$PATH"

set -e

echo "→ [1/5] Typecheck (tsc --noEmit)..."
npm run typecheck

echo "→ [2/5] Lint (eslint)..."
npm run lint

echo "→ [3/5] Unit tests (vitest)..."
npm run test:run

echo "→ [4/5] CSP sync check (audit:csp)..."
npm run audit:csp

echo "→ [5/5] E2E tests (playwright)..."
npm run test:e2e

echo "✓ Pre-push OK — push procede"
