{
  "name": "control-flotilla",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GPA fleet control — checklist + taller + historial",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "audit:xss": "node scripts/xss-audit.mjs \"Control de flotilla.html\"",
    "audit:baseline": "node scripts/verify-baseline.mjs",
    "audit:deps": "npm audit --omit=dev",
    "audit:csp": "node scripts/compute-csp-hashes.mjs --check",
    "csp:sync": "node scripts/compute-csp-hashes.mjs",
    "audit:all": "npm run audit:deps && npm run audit:xss && npm run audit:baseline && npm run audit:csp",
    "format": "prettier --write \"src/**/*.{ts,js,css,html}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "amplify:sandbox": "npx ampx sandbox",
    "amplify:sandbox:delete": "npx ampx sandbox delete",
    "amplify:generate": "npx ampx generate outputs"
  },
  "dependencies": {
    "aws-amplify": "^6.17.0",
    "echarts": "6.0.0",
    "jspdf": "4.2.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  }
}
